# Sales / NocoDB CRM environment variables
# Copy to .env (or merge into existing .env) and fill real values.
# DO NOT commit .env. This .example file is safe to commit.

# --- NocoDB connection ---
# Base URL of your NocoDB instance (e.g. self-hosted on GCP VM)
NOCODB_BASE_URL=https://nocodb.example.com

# Two tokens (ADR-001 — least privilege):
# WRITE token: used by n8n workflows AND mind-agent backend
NOCODB_API_TOKEN_WRITE=

# READ token: used by mind-id /satis UI (read-only)
NOCODB_API_TOKEN_READ=

# Backwards-compat: mind-agent code reads NOCODB_API_TOKEN if WRITE not set.
# Prefer NOCODB_API_TOKEN_WRITE going forward.
NOCODB_API_TOKEN=

# --- NocoDB table IDs ---
# Find these in NocoDB UI → Table → Settings → "Copy table ID"
NOCODB_LEADS_TABLE_ID=
NOCODB_MESSAGES_TABLE_ID=
NOCODB_NOTIFICATIONS_TABLE_ID=

# --- n8n webhook URLs (referenced by Zernio Inbox addon, etc.) ---
# Lead Toplama Agent webhook (generic intake)
N8N_LEAD_INTAKE_WEBHOOK_URL=

# Meta Lead Ads webhook (Meta will POST here after App Review approval)
N8N_META_LEAD_ADS_WEBHOOK_URL=

# --- Token rotation reminder ---
# NOCODB_TOKENS_LAST_ROTATED=2026-04-30  (informational only, set when rotated)

# --- Zernio (WhatsApp + Inbox API) ---
# API key from Zernio dashboard. Leave blank to disable Zernio MCP server.
ZERNIO_API_KEY=
# Base URL — override only for staging/self-hosted Zernio
ZERNIO_BASE_URL=https://api.zernio.com/v1
# WhatsApp account ID (default = Slowdays line)
ZERNIO_WA_ACCOUNT_ID=69ecc2273a63baf2053dfc21
# HMAC-SHA256 secret for /zernio/webhook verification.
# Generate with: openssl rand -hex 32
# If unset, webhook runs in soft mode (signature check skipped — dev only).
ZERNIO_WEBHOOK_SECRET=

# --- Zernio webhook event dispatcher (Part 1 expansion, 2026-05-22) ---
# Per-event feature flags. Default: every event handler is enabled.
# Set to false to short-circuit a specific event with a 200 ack (no side
# effects). Format: ZERNIO_EVENT_<EVENT_NAME_UPPER>_ENABLED.
# ZERNIO_EVENT_POST_PUBLISHED_ENABLED=true
# ZERNIO_EVENT_POST_FAILED_ENABLED=true
# ZERNIO_EVENT_ACCOUNT_DISCONNECTED_ENABLED=true
# ZERNIO_EVENT_COMMENT_RECEIVED_ENABLED=true
# ZERNIO_EVENT_MESSAGE_SENT_ENABLED=true
# ZERNIO_EVENT_POST_BOOST_COMPLETED_ENABLED=true

# Bekci Robot alert webhook (n8n) used by post.failed events.
# GUARDIAN_ALERT_WEBHOOK_URL=https://mindidai.app.n8n.cloud/webhook/bekci-alert
