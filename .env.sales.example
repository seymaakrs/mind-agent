# mind-agent — .env example for the Customer Agent (sales) system.
#
# Copy this file to ".env" and fill in real values. Never commit ".env".
# Schema source of truth: customer_agent/docs/NOCODB-SCHEMA-V2.md
#
# Existing core env vars (OPENAI_API_KEY, FIREBASE_*, LATE_API_KEY, etc.) are
# documented in CLAUDE.md and pre-existing .env files; they are NOT repeated
# here — this file ONLY covers the sales/customer-agent additions.

# ---------------------------------------------------------------------------
# Sales feature flag (master switch — default OFF)
# ---------------------------------------------------------------------------
# Setting this to "true" wires the 5 sales sub-agents into the orchestrator
# AND mounts the /sales/webhook/* routes onto the FastAPI app. While it is
# "false" the system behaves exactly like before; safe rollout.
SALES_AGENTS_ENABLED=false

# Şeyma's email — used by notify_seyma tool for hot-lead alerts.
SALES_SEYMA_EMAIL=seymaakrs@gmail.com

# ---------------------------------------------------------------------------
# NocoDB CRM (10 vars — all REQUIRED when SALES_AGENTS_ENABLED=true)
# ---------------------------------------------------------------------------
# Apply customer_agent/docs/NOCODB-SCHEMA-V2.md FIRST, then copy each table
# id from NocoDB UI → Table → ⋮ → "Copy table ID".
NOCODB_BASE_URL=https://nocodb.example.com
NOCODB_API_TOKEN=xc-token-here
NOCODB_LEADS_TABLE_ID=
NOCODB_MESSAGES_TABLE_ID=
NOCODB_NOTIFICATIONS_TABLE_ID=
NOCODB_CAMPAIGNS_TABLE_ID=
NOCODB_DAILY_METRICS_TABLE_ID=
NOCODB_DECISIONS_LOG_TABLE_ID=
NOCODB_OBJECTIONS_LOG_TABLE_ID=
NOCODB_AGENT_HEALTH_TABLE_ID=

# ---------------------------------------------------------------------------
# Zernio (15-platform unified social media API)
# ---------------------------------------------------------------------------
# Get the API key from Zernio dashboard → Settings → API Keys.
ZERNIO_API_KEY=zk_xxxxxxxxxxxx

# Override only if Zernio gave you a custom region or staging URL.
ZERNIO_BASE_URL=https://api.zernio.com

# Add-on toggles — must match what's actually enabled on Zernio dashboard.
# Set inbox_enabled=true ONLY after activating the $10/mo Inbox addon.
ZERNIO_INBOX_ENABLED=false
ZERNIO_ADS_ENABLED=false
ZERNIO_ANALYTICS_ENABLED=true

# Webhook signature secret — generated when you create the webhook in Zernio
# dashboard → Settings → Webhooks → "Add endpoint". Mind-agent uses this to
# verify HMAC-SHA256 signatures on every incoming /sales/webhook/zernio call.
# REQUIRED in production. In dev with DRY_RUN=true the check is bypassed.
ZERNIO_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Meta (Facebook) Lead Ads webhook (PARK status — App Review beklemede)
# ---------------------------------------------------------------------------
# Generated when you create the FB App webhook subscription. Same value
# you paste into Meta App Dashboard → Webhooks → "Verify Token".
META_VERIFY_TOKEN=
# App Secret from Meta App Dashboard → Settings → Basic → "App Secret".
META_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Clay (B2B prospecting) backend bridge — n8n proxy or direct Clay REST
# ---------------------------------------------------------------------------
# Optional. If unset, the discover_local_businesses tool returns NOT_FOUND
# (Clay agent surfaces this gracefully). Wire this when n8n's Clay-MCP bridge
# workflow is published OR when you have direct Clay REST creds.
CLAY_BACKEND_URL=
CLAY_BACKEND_TOKEN=
