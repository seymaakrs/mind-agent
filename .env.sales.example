# Sales / NocoDB CRM environment variables
# Copy to .env (or merge into existing .env) and fill real values.
# DO NOT commit .env. This .example file is safe to commit.

# --- NocoDB connection ---
# Base URL of your NocoDB instance (e.g. self-hosted on GCP VM)
NOCODB_BASE_URL=https://nocodb.example.com

# Two tokens (ADR-001 — least privilege):
# WRITE token: used by n8n workflows AND mind-agent backend
NOCODB_API_TOKEN_WRITE=

# READ token: used by mind-id /satis UI (read-only)
NOCODB_API_TOKEN_READ=

# Backwards-compat: mind-agent code reads NOCODB_API_TOKEN if WRITE not set.
# Prefer NOCODB_API_TOKEN_WRITE going forward.
NOCODB_API_TOKEN=

# --- NocoDB table IDs ---
# Find these in NocoDB UI → Table → Settings → "Copy table ID"
NOCODB_LEADS_TABLE_ID=
NOCODB_MESSAGES_TABLE_ID=
NOCODB_NOTIFICATIONS_TABLE_ID=

# --- n8n webhook URLs (referenced by Zernio Inbox addon, etc.) ---
# Lead Toplama Agent webhook (generic intake)
N8N_LEAD_INTAKE_WEBHOOK_URL=

# Meta Lead Ads webhook (Meta will POST here after App Review approval)
N8N_META_LEAD_ADS_WEBHOOK_URL=

# --- Token rotation reminder ---
# NOCODB_TOKENS_LAST_ROTATED=2026-04-30  (informational only, set when rotated)
